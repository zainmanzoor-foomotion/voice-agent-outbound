# =====================================================
# AI VOICE CALLING AGENT — ENVIRONMENT VARIABLES
# Copy this file to ".env" and fill in your real values.
# =====================================================

# App
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Vapi (https://dashboard.vapi.ai)
# - Private key: used by the backend to make API calls.
# - Public key: usable on the frontend if you ever add a Vapi Web SDK widget.
# - Phone Number ID: from "Phone Numbers" section of the Vapi dashboard.
# - Webhook secret (optional): any random string; Vapi echoes it back
#   on every webhook in the X-Vapi-Secret header so we can verify it.
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# Groq LLM (https://console.groq.com)
# Used for post-call extraction + summaries. Vapi will also use Groq
# internally for the conversation (configured via the Vapi API).
GROQ_API_KEY=

# Public base URL exposed by ngrok (no trailing slash)
# Example: https://abcd-1234.ngrok-free.app
BASE_URL=

# Business / sales agent identity (used inside the prompt)
BUSINESS_NAME=Acme AI Solutions
AGENT_NAME=Alex
BUSINESS_SERVICE=AI-powered business automation tools
